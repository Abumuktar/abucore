# Copy to .env and fill in real values. NEVER commit .env.

# MongoDB Atlas connection string
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/abucore?retryWrites=true&w=majority"
MONGODB_DB="abucore"

# Long random string used to sign admin session tokens
JWT_SECRET="replace-with-a-long-random-string"

# Seed values (used once by `npm run seed` to create the MD admin login)
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="set-a-strong-password"

# Email notifications via Gmail SMTP.
# GMAIL_PASS is a Gmail App Password (https://myaccount.google.com/apppasswords), not your login password.
GMAIL_USER="you@gmail.com"
GMAIL_PASS="your-16-char-app-password"
NOTIFY_EMAIL="you@example.com"
